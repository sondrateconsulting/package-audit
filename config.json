{
    "concurrency": {
        "branches": 4,
        "organizations": 3,
        "repositories": 6
    },
    "cutoffDate": "2024-01-01",
    "excludeDirGlobs": [
        "**/node_modules/**",
        "**/dist/**",
        "**/build/**",
        "**/vendor/**"
    ],
    "githubHost": "github.com",
