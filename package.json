{
  "name": "package-audit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "READ-ONLY npm-package-usage auditor over GitHub orgs (gh CLI + Bun + SQLite)",
  "scripts": {
    "audit": "bun run scripts/orchestrate.ts",
    "report": "bun run scripts/report.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@types/bun": "1.2.19",
    "zod": "4.4.3"
  }
}
