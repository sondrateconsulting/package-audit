{
  "name": "package-audit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "READ-ONLY npm-package-usage auditor over GitHub orgs (gh CLI + Bun + SQLite)",
  "scripts": {
    "audit": "bun run scripts/orchestrate.ts",
    "report": "bun run scripts/report.ts",
    "export": "bun run scripts/export.ts",
    "compare": "bun run scripts/compare.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "ink": "7.1.1",
    "react": "19.2.7",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "ink-testing-library": "4.0.0",
    "zod": "4.4.3"
  }
}
